<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>TrueMetrics.Xamarin.Android</id>
    <version>1.5.9</version>
    <title>TrueMetrics SDK for Xamarin Android</title>
    <authors>TrueMetrics</authors>
    <owners>TrueMetrics</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/TRUE-Metrics-io/truemetrics_android_SDK</projectUrl>
    <repository type="git" url="https://github.com/TRUE-Metrics-io/truemetrics_android_SDK" />
    <description>
      Xamarin.Android binding for TrueMetrics SDK 1.5.0 — sensor data collection for last-mile delivery applications.
      
      This package provides a C# binding for the native Android TrueMetrics SDK, enabling Xamarin.Forms and .NET MAUI 
      applications to integrate sensor-based data collection for delivery tracking and logistics optimization.
      
      Key Features:
      - Automatic sensor data collection (GPS, accelerometer, gyroscope, barometer)
      - Background recording with foreground service
      - Automatic data compression and upload
      - Real-time sensor status monitoring
      - Encrypted local data storage
      - Configurable recording parameters
    </description>
    <releaseNotes>
      Version 1.5.9 - EMBEDDED ALL RUNTIME DEPENDENCIES (Permanent Fix)
      - Embedded Koin DI 4.1.1 JARs directly in binding DLL (fixes NoClassDefFoundError for KoinApplicationKt)
      - Embedded Ktor Client 3.3.0 JARs directly in binding DLL (fixes potential runtime errors)
      - All dependencies (Timber, Koin, Ktor) now compiled into TrueMetrics.Xamarin.Android.dll
      - No external NuGet packages needed for these dependencies
      - Fixes all Java.Lang.NoClassDefFoundError runtime exceptions
      - Version 1.5.8 changes:
        - Embedded Timber 5.0.1 classes directly in binding DLL
      - Version 1.5.7 changes:
        - Attempted to embed Timber AAR (did not work at runtime)
      - Version 1.5.6 changes:
        - Added missing Timber logging dependency
      - Version 1.5.5 changes:
        - Fixed CS0108 warnings for Status._members hiding inherited members
        - Fixed duplicate nested type name warnings by removing duplicate Companion objects
        - Fixed unexpected field type warnings in TruemetricsSdk
      - Version 1.5.4 changes:
        - Added persistent notification support for background recording
        - Added TrueMetricsNotificationFactory for foreground service notifications
      - Added TrueMetricsNotificationHelper for notification channel management
      - Added InitializeWithNotification() method for easy setup
      - Added Xamarin.AndroidX.Core dependency for NotificationCompat
      - Ensures SDK works properly in background with persistent notification
      - All notifications use dedicated channel ID: truemetrics_recording_channel
    </releaseNotes>
    <copyright>Copyright © TrueMetrics 2024</copyright>
    <tags>xamarin android truemetrics sensor binding last-mile delivery logistics tracking</tags>
    <dependencies>
      <group targetFramework="monoandroid13.0">
        <dependency id="Xamarin.Kotlin.StdLib" version="1.7.10" />
        <dependency id="Xamarin.KotlinX.Coroutines.Android" version="1.6.4" />
        <dependency id="Xamarin.GooglePlayServices.Location" version="118.0.0.1" />
        <dependency id="Xamarin.AndroidX.Core" version="1.9.0.1" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- Reference assemblies -->
    <file src="bin\Release\TrueMetrics.Xamarin.Android.dll" target="lib\monoandroid13.0" />
    <file src="bin\Release\TrueMetrics.Xamarin.Android.xml" target="lib\monoandroid13.0" />
    
    <!-- Documentation -->
    <file src="..\README.md" target="docs" />
  </files>
</package>
