<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <ProjectTypeGuids>{10368E6C-D01B-4462-8E8B-01F6676C6E6C};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <TemplateGuid>{11b6dfd1-8a42-4e8e-9e0b-7e3b7c5b5e9a}</TemplateGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>TrueMetrics.Xamarin.Android</RootNamespace>
    <AssemblyName>TrueMetrics.Xamarin.Android</AssemblyName>
    <FileAlignment>512</FileAlignment>
    <Deterministic>True</Deterministic>
    <TargetFrameworkVersion>v13.0</TargetFrameworkVersion>
    <AndroidClassParser>class-parse</AndroidClassParser>
    <AndroidCodegenTarget>XAJavaInterop1</AndroidCodegenTarget>
    <LangVersion>9.0</LangVersion>
    
    <!-- NuGet Package Configuration -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>TrueMetrics.Xamarin.Android</PackageId>
    <PackageVersion>1.5.8</PackageVersion>
    <Authors>TrueMetrics</Authors>
    <Company>TrueMetrics</Company>
    <Description>Xamarin.Android binding for TrueMetrics SDK 1.5.0 - sensor data collection for last-mile delivery applications. Includes Timber logging dependency.</Description>
    <PackageTags>xamarin android truemetrics sensor binding last-mile delivery</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/TRUE-Metrics-io/truemetrics_android_SDK</PackageProjectUrl>
    <RepositoryUrl>https://github.com/TRUE-Metrics-io/truemetrics_android_SDK</RepositoryUrl>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    
    <!-- Nuspec reference -->
    <NuspecFile>TrueMetrics.Xamarin.Android.nuspec</NuspecFile>
    <NuspecProperties>version=$(PackageVersion)</NuspecProperties>
  </PropertyGroup>
  
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>portable</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>portable</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <DocumentationFile>bin\Release\TrueMetrics.Xamarin.Android.xml</DocumentationFile>
  </PropertyGroup>
  
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Core" />
    <Reference Include="Mono.Android" />
    <Reference Include="Java.Interop" />
  </ItemGroup>
  
  <ItemGroup>
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="Transforms\Additions.cs" />
  </ItemGroup>
  
  <ItemGroup>
    <!-- AAR Library -->
    <LibraryProjectZip Include="Jars\truemetricssdk-1.5.0.aar" />
    
    <!-- Transforms -->
    <TransformFile Include="Transforms\Metadata.xml" />
    <TransformFile Include="Transforms\EnumMethods.xml" />
  </ItemGroup>
  
  <ItemGroup>
    <!-- Minimal dependencies - SDK embeds other libraries internally -->
    <PackageReference Include="Xamarin.Kotlin.StdLib">
      <Version>1.7.10</Version>
    </PackageReference>
    <PackageReference Include="Xamarin.KotlinX.Coroutines.Android">
      <Version>1.6.4</Version>
    </PackageReference>
    <PackageReference Include="Xamarin.GooglePlayServices.Location">
      <Version>118.0.0.1</Version>
    </PackageReference>
    <PackageReference Include="Xamarin.AndroidX.Core">
      <Version>1.10.1.1</Version>
    </PackageReference>
  </ItemGroup>
  
  <!-- Embedded JARs for dependencies without Xamarin bindings -->
  <ItemGroup>
    <!-- Ktor Client - No official Xamarin binding available -->
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-client-core-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-client-core-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-client-android-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-client-android-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-client-content-negotiation-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-client-content-negotiation-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-client-logging-jvm-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-client-logging-jvm-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-client-encoding-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-client-encoding-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-serialization-kotlinx-json-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-serialization-kotlinx-json-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-serialization-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-serialization-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-client-okhttp-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-client-okhttp-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-http-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-http-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-utils-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-utils-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-io-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-io-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-events-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-events-3.3.0.jar')" />
    <EmbeddedReferenceJar Include="Jars\ktor\ktor-websockets-3.3.0.jar" Condition="Exists('Jars\ktor\ktor-websockets-3.3.0.jar')" />
    
    <!-- Koin Dependency Injection - No official Xamarin binding -->
    <EmbeddedReferenceJar Include="Jars\koin\koin-core-4.1.1.jar" Condition="Exists('Jars\koin\koin-core-4.1.1.jar')" />
    <EmbeddedReferenceJar Include="Jars\koin\koin-core-jvm-4.1.1.jar" Condition="Exists('Jars\koin\koin-core-jvm-4.1.1.jar')" />
    <EmbeddedReferenceJar Include="Jars\koin\koin-android-4.1.1.aar" Condition="Exists('Jars\koin\koin-android-4.1.1.aar')" />
    
    <!-- Timber Logging - Embedded directly in binding DLL -->
    <EmbeddedReferenceJar Include="Jars\timber-5.0.1.jar" />
  </ItemGroup>
  
  <Import Project="$(MSBuildExtensionsPath)\Xamarin\Android\Xamarin.Android.Bindings.targets" />
</Project>
